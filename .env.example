# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Detection Settings
CONFIDENCE_THRESHOLD=0.45
# Stricter threshold for animal class (reduces person-as-animal false positives)
ANIMAL_CONFIDENCE_THRESHOLD=0.65
ALERT_COOLDOWN_SECONDS=30
MOTION_MIN_AREA=1500
# Vote buffer: detection type must appear in VOTE_THRESHOLD of last VOTE_WINDOW frames
VOTE_WINDOW=5
VOTE_THRESHOLD=3

# Input Source: "webcam", "video", "esp32cam"
INPUT_SOURCE=webcam
# Path to video file (used if INPUT_SOURCE=video)
VIDEO_FILE_PATH=data/test_video.mp4
# ESP32-CAM MJPEG stream URL (used if INPUT_SOURCE=esp32cam)
ESP32CAM_URL=http://192.168.1.100/stream

# Webcam device index (usually 0)
WEBCAM_INDEX=0

# Zone Configuration (JSON list of zone names)
# Zones are simulated in software; hardware zones added in H1/H3
ZONES=["Main Entrance", "Corridor", "Backyard", "Side Gate"]

# Database
DATABASE_URL=sqlite:///data/incidents.db

# Snapshot storage directory
SNAPSHOT_DIR=snapshots

# YOLO model variant. yolov8s is the default (good accuracy/speed balance on CPU).
# Options: yolov8n.pt (fastest, least accurate), yolov8s.pt, yolov8m.pt (slower, most accurate)
YOLO_MODEL_PATH=models/yolov8s.pt
# Smaller = faster inference for the main COCO model
YOLO_INFER_IMGSZ=640
# Monkey specialist: directory containing best.pt (Ultralytics export), or leave default ./best
# MONKEY_MODEL_DIR=best
# Or set explicit file: MONKEY_MODEL_PATH=models/monkey_best.pt
# Smaller imgsz = lower latency when running main + monkey each frame
MONKEY_INFER_IMGSZ=416
MONKEY_CONFIDENCE_THRESHOLD=0.55

# Mock PIR: fire a simulated motion event every N seconds (0 = disabled).
# Keep at 0 during testing — use the "Fire Mock PIR" button in the dashboard instead.
MOCK_PIR_INTERVAL=0

# Server
HOST=0.0.0.0
PORT=8000

# JWT Security (CHANGE the secret in production!)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
ADMIN_EMAIL=admin@yourdomain.com

# Reports output directory
REPORTS_DIR=reports

# Data retention in days (0 = keep forever)
DATA_RETENTION_DAYS=30
